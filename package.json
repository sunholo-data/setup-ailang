{
  "name": "setup-ailang",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action to install the AILANG compiler.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && ncc build lib/main.js -o dist --source-map --license licenses.txt",
    "package": "ncc build lib/main.js -o dist --source-map --license licenses.txt",
    "all": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sunholo-data/setup-ailang.git"
  },
  "keywords": ["actions", "ailang", "setup"],
  "license": "MIT",
  "dependencies": {
    "@actions/cache": "^4.0.0",
    "@actions/core": "^1.10.1",
    "@actions/http-client": "^2.2.3",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.3.3"
  }
}
